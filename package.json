{
  "name": "pharmacy-saas-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "desktop:start": "npm run build && electron .",
    "desktop:prepare": "node scripts/prepare-desktop.cjs",
    "desktop:dist": "npm run build && npm run desktop:prepare && electron-builder --win --x64"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "react": "^19.2.4",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.2",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.4",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.index.pharma.desktop",
    "productName": "Index Pharma Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop-bundle/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "desktop-bundle/app",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
